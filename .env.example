# Flask
SECRET_KEY=your-secret-key-here
FLASK_DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/autobizops

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# N8N Webhook
N8N_BLOG_GENERATION_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/your-webhook-id
